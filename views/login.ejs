<!DOCTYPE html>
<html lang="<%= locale %>">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= branding.shortName %> - <%= __('ADMIN_LOGIN_TITLE') %></title>
    <link rel="stylesheet" href="<%= url('/static/style.css') %>" />
    <style>
      :root {
        --color-primary: <%= branding.colors.primary %>;
        --color-primary-hover: <%= branding.colors.primaryHover %>;
      }
    </style>
  </head>
  <body class="bg-gray-100 h-screen flex items-center justify-center relative font-sans">
    <div class="absolute top-0 left-0 w-full h-1/3 bg-primary rounded-b-[3rem] shadow-md z-0"></div>

    <div class="bg-white p-10 rounded-3xl shadow-2xl w-96 relative z-10 border border-gray-100">
      <div class="text-center mb-8">
        <h2 class="font-brand-serif text-2xl tracking-tight text-gray-800">
          <%= branding.name %> <span class="text-primary"><%= branding.accentText %></span>
        </h2>
      </div>

      <% if (locals.error) { %>
      <p
        class="bg-red-50 text-red-600 p-3 rounded-lg mb-6 text-center text-sm font-semibold border border-red-100"
      >
        <%= error %>
      </p>
      <% } %>

      <form method="POST" action="<%= url('/admin/login') %>">
        <input
          type="password"
          name="password"
          placeholder="<%= __('LOGIN_PASSWORD_PLACEHOLDER') %>"
          class="w-full p-4 bg-gray-50 border border-gray-300 rounded-xl mb-6 focus:outline-none focus:ring-2 focus:ring-primary"
          required
        />
        <button
          class="w-full bg-primary hover:bg-primary-hover text-white font-bold p-4 rounded-xl transition shadow-md cursor-pointer"
        >
          <%= __('LOGIN_BTN') %>
        </button>
      </form>
    </div>
  </body>
</html>
