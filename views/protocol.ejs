<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>KTV - Protokoll & Abrechnung</title>
    <script src="<%= url('/static/tailwind.js') %>"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&display=swap');
        .bg-ktv { background-color: #76a59d; }
        .text-ktv { color: #76a59d; }
        .border-ktv { border-color: #76a59d; }
        .font-ktv-serif { font-family: 'Playfair Display', serif; }
    </style>
</head>
<body class="bg-[#f8fafa] text-gray-800 font-sans min-h-screen">

    <nav class="bg-white border-b border-gray-200 py-4 px-6 sticky top-0 z-50 shadow-sm">
        <div class="container mx-auto flex justify-between items-center">
            <div class="flex items-center gap-4">
                <a href="<%= url('/admin') %>" class="bg-gray-100 p-2 rounded-lg hover:bg-gray-200 transition">
                    <svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
                </a>
                <div>
                    <h1 class="font-ktv-serif text-xl leading-tight">Protokoll <span class="text-ktv">& Abrechnung</span></h1>
                    <p class="text-[9px] uppercase tracking-[0.2em] text-gray-400 font-bold">Klagenfurter Turnverein 1862</p>
                </div>
            </div>
            <a href="<%= url('/admin/export?month=' + filters.month) %>" class="bg-ktv text-white px-4 py-2 rounded-xl text-xs font-bold shadow-md hover:bg-[#65918a] transition flex items-center gap-2">
                📊 Excel Export (<%= filters.month %>)
            </a>
        </div>
    </nav>

    <main class="container mx-auto p-6">
        
        <!-- Filter Bar -->
        <section class="bg-white rounded-3xl shadow-sm border border-gray-100 p-6 mb-8">
            <form id="filterForm" method="GET" action="<%= url('/admin/protocol') %>" class="grid grid-cols-1 md:grid-cols-5 gap-4 items-end">
                <% 
                    const [fYear, fMonth] = filters.month.split('-');
                    const months = ['Januar', 'Februar', 'März', 'April', 'Mai', 'Juni', 'Juli', 'August', 'September', 'Oktober', 'November', 'Dezember'];
                    const currentYear = new Date().getFullYear();
                %>
                <div>
                    <label class="block text-xs font-bold text-gray-400 uppercase mb-1">Jahr</label>
                    <select id="selectYear" class="w-full bg-gray-50 border border-gray-200 p-2.5 rounded-xl text-sm outline-none focus:ring-2 ring-ktv">
                        <% for(let y = currentYear; y >= currentYear - 5; y--) { %>
                            <option value="<%= y %>" <%= fYear == y ? 'selected' : '' %>><%= y %></option>
                        <% } %>
                    </select>
                </div>
                <div>
                    <label class="block text-xs font-bold text-gray-400 uppercase mb-1">Monat</label>
                    <select id="selectMonth" class="w-full bg-gray-50 border border-gray-200 p-2.5 rounded-xl text-sm outline-none focus:ring-2 ring-ktv">
                        <% months.forEach((m, i) => { %>
                            <option value="<%= String(i + 1).padStart(2, '0') %>" <%= fMonth == String(i + 1).padStart(2, '0') ? 'selected' : '' %>><%= m %></option>
                        <% }) %>
                    </select>
                </div>
                <input type="hidden" name="month" id="hiddenMonth" value="<%= filters.month %>">

                <div>
                    <label class="block text-xs font-bold text-gray-400 uppercase mb-1">Trainer/in</label>
                    <select name="trainer" class="w-full bg-gray-50 border border-gray-200 p-2.5 rounded-xl text-sm outline-none focus:ring-2 ring-ktv">
                        <option value="">-- Alle --</option>
                        <% trainers.forEach(t => { %>
                            <option value="<%= t.id %>" <%= filters.trainer == t.id ? 'selected' : '' %>><%= t.name %></option>
                        <% }) %>
                    </select>
                </div>
                <div>
                    <label class="block text-xs font-bold text-gray-400 uppercase mb-1">Turnhalle</label>
                    <select name="hall" class="w-full bg-gray-50 border border-gray-200 p-2.5 rounded-xl text-sm outline-none focus:ring-2 ring-ktv">
                        <option value="">-- Alle --</option>
                        <% halls.forEach(h => { %>
                            <option value="<%= h.id %>" <%= filters.hall == h.id ? 'selected' : '' %>><%= h.name %></option>
                        <% }) %>
                    </select>
                </div>
                <button type="submit" class="bg-gray-800 text-white font-bold py-2.5 rounded-xl text-sm shadow-md hover:bg-black transition">Filtern</button>
            </form>
        </section>

        <% 
            let totalMins = 0;
            let totalPay = 0;
            const hourlyWage = parseFloat(settings.hourly_wage);
            logs.forEach(log => {
                totalMins += (log.duration_minutes || 0);
                totalPay += (log.duration_minutes ? (log.duration_minutes / 60 * hourlyWage) : 0);
            });
        %>

        <!-- Summary Cards -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
            <div class="bg-white p-6 rounded-3xl border border-gray-100 shadow-sm">
                <p class="text-xs font-bold text-gray-400 uppercase mb-1">Einheiten</p>
                <p class="text-3xl font-ktv-serif text-gray-800"><%= logs.length %></p>
            </div>
            <div class="bg-white p-6 rounded-3xl border border-gray-100 shadow-sm">
                <p class="text-xs font-bold text-gray-400 uppercase mb-1">Gesamtzeit</p>
                <p class="text-3xl font-ktv-serif text-gray-800"><%= Math.floor(totalMins / 60) %>h <%= totalMins % 60 %>m</p>
            </div>
            <div class="bg-white p-6 rounded-3xl border border-ktv/20 shadow-sm bg-ktv/5">
                <p class="text-xs font-bold text-ktv uppercase mb-1">Gesamtentschädigung</p>
                <p class="text-3xl font-ktv-serif text-ktv"><%= totalPay.toFixed(2) %> €</p>
                <p class="text-[10px] text-gray-400 mt-1">Basis: <%= hourlyWage.toFixed(2) %> € / Std.</p>
            </div>
        </div>

        <!-- Table -->
        <section class="bg-white rounded-3xl shadow-sm border border-gray-100 overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-left text-sm">
                    <thead class="bg-gray-50 text-gray-400 uppercase text-[9px] tracking-[0.1em] font-bold">
                        <tr>
                            <th class="px-6 py-4">Trainer / Halle</th>
                            <th class="px-6 py-4">Datum / Zeit</th>
                            <th class="px-6 py-4">Dauer</th>
                            <th class="px-6 py-4 text-right">Entschädigung</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-50">
                        <% logs.forEach(log => { 
                            const sessionPay = log.duration_minutes ? (log.duration_minutes / 60 * hourlyWage) : 0;
                        %>
                            <tr class="hover:bg-gray-50 transition">
                                <td class="px-6 py-4">
                                    <div class="font-bold text-gray-700"><%= log.trainer %></div>
                                    <div class="text-[10px] text-ktv uppercase font-bold"><%= log.hall %></div>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <div class="text-gray-800 text-xs font-medium">
                                        <%= new Date(log.start_timestamp + " UTC").toLocaleDateString('de-AT', { day:'2-digit', month:'2-digit', year:'numeric' }) %>
                                    </div>
                                    <div class="text-[10px] text-gray-400">
                                        <%= new Date(log.start_timestamp + " UTC").toLocaleTimeString('de-AT', { hour:'2-digit', minute:'2-digit' }) %> - 
                                        <%= log.end_timestamp ? new Date(log.end_timestamp + " UTC").toLocaleTimeString('de-AT', { hour:'2-digit', minute:'2-digit' }) : '...' %>
                                    </div>
                                </td>
                                <td class="px-6 py-4">
                                    <% if (log.end_timestamp !== null) { %>
                                        <span class="px-2 py-1 bg-ktv/10 text-ktv rounded-md text-[10px] font-bold">
                                            <%= log.duration_minutes %> Min.
                                        </span>
                                    <% } else { %>
                                        <span class="px-2 py-1 bg-yellow-100 text-yellow-700 rounded-md text-[10px] font-bold animate-pulse">
                                            Läuft...
                                        </span>
                                    <% } %>
                                </td>
                                <td class="px-6 py-4 text-right font-mono font-bold text-gray-700">
                                    <%= sessionPay > 0 ? sessionPay.toFixed(2) + ' €' : '-' %>
                                </td>
                            </tr>
                        <% }) %>
                        <% if (logs.length === 0) { %>
                            <tr><td colspan="4" class="px-6 py-20 text-center text-gray-300 italic">Keine Einträge für diesen Zeitraum gefunden.</td></tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </section>
    </main>

    <script>
        document.getElementById('filterForm').addEventListener('submit', function() {
            const year = document.getElementById('selectYear').value;
            const month = document.getElementById('selectMonth').value;
            document.getElementById('hiddenMonth').value = `${year}-${month}`;
        });
    </script>
</body>
</html>