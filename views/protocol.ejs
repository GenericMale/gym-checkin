<!DOCTYPE html>
<html lang="<%= locale %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= __('ADMIN_PROTOCOL_TITLE') %></title>
    <link rel="stylesheet" href="<%= url('/static/style.css') %>">
</head>
<body class="bg-[#f8fafa] text-gray-800 font-sans min-h-screen">

    <nav class="bg-white border-b border-gray-200 py-4 px-6 sticky top-0 z-50 shadow-sm">
        <div class="container mx-auto flex justify-between items-center text-sm">
            <div class="flex items-center gap-4">
                <a href="<%= url('/admin') %>" class="bg-gray-100 p-2 rounded-lg hover:bg-gray-200 transition">
                    <svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
                </a>
                <div>
                    <h1 class="font-ktv-serif text-xl leading-tight"><%= __('ADMIN_PROTOCOL_TITLE') %></h1>
                    <p class="text-[9px] uppercase tracking-[0.2em] text-gray-400 font-bold"><%= __('APP_NAME') %> <%= __('APP_YEAR') %></p>
                </div>
            </div>
            <div class="flex gap-4">
                <% if (logs.length > 0) { %>
                    <button id="deleteAllShown" class="bg-red-50 text-red-600 px-4 py-2 rounded-xl text-xs font-bold hover:bg-red-100 transition flex items-center gap-2">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                        <%= __('ADMIN_DELETE_ALL_SHOWN') %>
                    </button>
                <% } %>
                <a href="<%= url('/admin/export?month=' + filters.month + (filters.trainer ? '&trainer=' + filters.trainer : '') + (filters.hall ? '&hall=' + filters.hall : '')) %>" class="bg-ktv text-white px-4 py-2 rounded-xl text-xs font-bold shadow-md hover:bg-ktv-hover transition flex items-center gap-2">
                    <%= __('ADMIN_EXCEL_EXPORT') %>
                </a>
            </div>
        </div>
    </nav>

    <main class="container mx-auto p-6">

        <!-- Filter Bar -->
        <section class="bg-white rounded-3xl shadow-sm border border-gray-100 p-6 mb-8">
            <form id="filterForm" method="GET" action="<%= url('/admin/protocol') %>" class="grid grid-cols-1 md:grid-cols-5 gap-4 items-end">
                <%
                    const [fYear, fMonth] = filters.month.split('-');
                    const currentYear = new Date().getFullYear();
                    const monthKeys = ['01', '02', '03', '04', '05', '06', '07', '08', '09', '10', '11', '12'];
                %>
                <div>
                    <label class="block text-xs font-bold text-gray-400 uppercase mb-1"><%= __('ADMIN_YEAR') %></label>
                    <select id="selectYear" class="w-full bg-gray-50 border border-gray-200 p-2.5 rounded-xl text-sm outline-none focus:ring-2 ring-ktv">
                        <% for(let y = currentYear; y >= currentYear - 5; y--) { %>
                            <option value="<%= y %>" <%= fYear == y ? 'selected' : '' %>><%= y %></option>
                        <% } %>
                    </select>
                </div>
                <div>
                    <label class="block text-xs font-bold text-gray-400 uppercase mb-1"><%= __('ADMIN_MONTH') %></label>
                    <select id="selectMonth" class="w-full bg-gray-50 border border-gray-200 p-2.5 rounded-xl text-sm outline-none focus:ring-2 ring-ktv">
                        <% monthKeys.forEach((key) => { %>
                            <option value="<%= key %>" <%= fMonth == key ? 'selected' : '' %>><%= __('MONTHS.' + key) %></option>
                        <% } ) %>
                    </select>
                </div>
                <input type="hidden" name="month" id="hiddenMonth" value="<%= filters.month %>">

                <div>
                    <label class="block text-xs font-bold text-gray-400 uppercase mb-1"><%= __('ADMIN_TRAINER_FILTER') %></label>
                    <select name="trainer" class="w-full bg-gray-50 border border-gray-200 p-2.5 rounded-xl text-sm outline-none focus:ring-2 ring-ktv">
                        <option value=""><%= __('ADMIN_ALL') %></option>
                        <% trainers.forEach(t => { %>
                            <option value="<%= t.id %>" <%= filters.trainer == t.id ? 'selected' : '' %>><%= t.name %></option>
                        <% }) %>
                    </select>
                </div>
                <div>
                    <label class="block text-xs font-bold text-gray-400 uppercase mb-1"><%= __('ADMIN_HALL_FILTER') %></label>
                    <select name="hall" class="w-full bg-gray-50 border border-gray-200 p-2.5 rounded-xl text-sm outline-none focus:ring-2 ring-ktv">
                        <option value=""><%= __('ADMIN_ALL') %></option>
                        <% halls.forEach(h => { %>
                            <option value="<%= h.id %>" <%= filters.hall == h.id ? 'selected' : '' %>><%= h.name %></option>
                        <% }) %>
                    </select>
                </div>
                <button type="submit" class="bg-gray-800 text-white font-bold py-2.5 rounded-xl text-sm shadow-md hover:bg-black transition"><%= __('ADMIN_FILTER_BTN') %></button>
            </form>
        </section>

        <%
            let totalMins = 0;
            let totalPay = 0;
            const hourlyWage = parseFloat(settings.hourly_wage);
            logs.forEach(log => {
                totalMins += (log.duration_minutes || 0);
                totalPay += (log.duration_minutes ? (log.duration_minutes / 60 * hourlyWage) : 0);
            });
        %>

        <!-- Summary Cards -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
            <div class="bg-white p-6 rounded-3xl border border-gray-100 shadow-sm">
                <p class="text-xs font-bold text-gray-400 uppercase mb-1"><%= __('ADMIN_UNITS') %></p>
                <p class="text-3xl font-ktv-serif text-gray-800"><%= logs.length %></p>
            </div>
            <div class="bg-white p-6 rounded-3xl border border-gray-100 shadow-sm">
                <p class="text-xs font-bold text-gray-400 uppercase mb-1"><%= __('ADMIN_TOTAL_TIME') %></p>
                <p class="text-3xl font-ktv-serif text-gray-800"><%= Math.floor(totalMins / 60) %>h <%= totalMins % 60 %>m</p>
            </div>
            <div class="p-6 rounded-3xl border border-ktv/20 shadow-sm bg-ktv/5">
                <p class="text-xs font-bold text-ktv uppercase mb-1"><%= __('ADMIN_TOTAL_COMPENSATION') %></p>
                <p class="text-3xl font-ktv-serif text-ktv"><%= totalPay.toFixed(2) %> €</p>
                <p class="text-[10px] text-gray-400 mt-1"><%= __('ADMIN_BASIS') %>: <%= hourlyWage.toFixed(2) %> € / Std.</p>
            </div>
        </div>

        <!-- Table -->
        <section class="bg-white rounded-3xl shadow-sm border border-gray-100 overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-left text-sm">
                    <thead class="bg-gray-50 text-gray-400 uppercase text-[9px] tracking-widest font-bold">
                        <tr>
                            <th class="px-6 py-4"><%= __('ADMIN_TABLE_TRAINER_HALL') %></th>
                            <th class="px-6 py-4"><%= __('ADMIN_TABLE_DATE_TIME') %></th>
                            <th class="px-6 py-4"><%= __('ADMIN_TABLE_DURATION') %></th>
                            <th class="px-6 py-4 text-right"><%= __('ADMIN_TABLE_COMPENSATION') %></th>
                            <th class="px-6 py-4"></th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-50">
                        <% logs.forEach(log => {
                            const sessionPay = log.duration_minutes ? (log.duration_minutes / 60 * hourlyWage) : 0;
                        %>
                            <tr class="hover:bg-gray-50 transition group">
                                <td class="px-6 py-4">
                                    <div class="font-bold text-gray-700"><%= log.trainer %></div>
                                    <div class="text-[10px] text-ktv uppercase font-bold"><%= log.hall %></div>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <div class="text-gray-800 text-xs font-medium">
                                        <%= new Date(log.start_timestamp + " UTC").toLocaleDateString(locale || 'de', { day:'2-digit', month:'2-digit', year:'numeric' }) %>
                                    </div>
                                    <div class="text-[10px] text-gray-400">
                                        <%= new Date(log.start_timestamp + " UTC").toLocaleTimeString(locale || 'de', { hour:'2-digit', minute:'2-digit' }) %> -
                                        <%= log.end_timestamp ? new Date(log.end_timestamp + " UTC").toLocaleTimeString(locale || 'de', { hour:'2-digit', minute:'2-digit' }) : '...' %>
                                    </div>
                                </td>
                                <td class="px-6 py-4">
                                    <% if (log.end_timestamp !== null) { %>
                                        <span class="px-2 py-1 bg-ktv/10 text-ktv rounded-md text-[10px] font-bold">
                                            <%= log.duration_minutes %> Min.
                                        </span>
                                    <% } else { %>
                                        <span class="px-2 py-1 bg-yellow-100 text-yellow-700 rounded-md text-[10px] font-bold animate-pulse">
                                            <%= __('ADMIN_TABLE_RUNNING') %>
                                        </span>
                                    <% } %>
                                </td>
                                <td class="px-6 py-4 text-right font-mono font-bold text-gray-700">
                                    <%= sessionPay > 0 ? sessionPay.toFixed(2) + ' €' : '-' %>
                                </td>
                                <td class="px-6 py-4 text-right">
                                    <button class="delete-btn text-gray-300 hover:text-red-600 transition p-2" data-id="<%= log.id %>">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                                    </button>
                                </td>
                            </tr>
                        <% }) %>
                        <% if (logs.length === 0) { %>
                            <tr><td colspan="5" class="px-6 py-20 text-center text-gray-300 italic"><%= __('ADMIN_TABLE_NO_ENTRIES') %></td></tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </section>
    </main>

    <script>
        document.getElementById('filterForm').addEventListener('submit', function() {
            const year = document.getElementById('selectYear').value;
            const month = document.getElementById('selectMonth').value;
            document.getElementById('hiddenMonth').value = `${year}-${month}`;
        });

        document.querySelectorAll('.delete-btn').forEach(btn => {
            btn.addEventListener('click', async function() {
                if (confirm('<%= __('ADMIN_DELETE_CONFIRM') %>')) {
                    const id = this.getAttribute('data-id');
                    const response = await fetch(`<%= url('/admin/delete-checkin/') %>${id}`, { method: 'POST' });
                    if (response.ok) {
                        location.reload();
                    }
                }
            });
        });

        const deleteAllBtn = document.getElementById('deleteAllShown');
        if (deleteAllBtn) {
            deleteAllBtn.addEventListener('click', async function() {
                if (confirm('<%= __('ADMIN_DELETE_ALL_CONFIRM') %>')) {
                    const params = new URLSearchParams(window.location.search);
                    const month = params.get('month') || '<%= filters.month %>';
                    const trainer = params.get('trainer') || '';
                    const hall = params.get('hall') || '';

                    const response = await fetch(`<%= url('/admin/delete-filtered-checkins') %>`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ month, trainer, hall })
                    });
                    if (response.ok) {
                        location.reload();
                    }
                }
            });
        }
    </script>
</body>
</html>
